# ╔══════════════════════════════════════════════════════╗
# ║  IVONNE STORE — Exemplo de variáveis de ambiente     ║
# ║  Copie este arquivo para .env e preencha os valores  ║
# ║  cp .env.example .env                                ║
# ╚══════════════════════════════════════════════════════╝

# ── Supabase ──────────────────────────────────────────
# Encontre em: https://supabase.com → Projeto → Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── Painel Administrativo ─────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=sua_senha_aqui

# ── Cupom ─────────────────────────────────────────────
COUPON_CODE=seu_codigo_de_cupom
COUPON_VALIDITY=31/07/2026
